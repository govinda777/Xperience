{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["**/*", "../src/types/**/*"],
  "exclude": ["node_modules", "../node_modules", "**/node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
