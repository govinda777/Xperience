datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model UserXp {
  userId        String   @id @map("user_id")
  walletAddress String?  @unique @map("wallet_address")
  totalXp       Int      @default(0) @map("total_xp")
  level         Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  history       XpTransaction[]

  @@index([walletAddress])
}

model XpTransaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Int
  reason    String
  nonce     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  user      UserXp   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
}

model MissionCooldown {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  missionKey  String    @map("mission_key")
  expiresAt   DateTime  @map("expires_at")
  lastClaimed DateTime  @default(now()) @map("last_claimed")

  @@unique([userId, missionKey])
  @@index([userId])
}

model User {
  id           String   @id @default(uuid())
  walletNumber String   @unique @map("wallet_number")
  privyId      String   @unique @map("privy_id")
  companyId    String?  @map("company_id")
  parentId     String?  @map("parent_id")
  departmentId String?  @map("department_id")
  role         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company         Company?         @relation(fields: [companyId], references: [id])
  parent          User?            @relation("UserToParent", fields: [parentId], references: [id])
  children        User[]           @relation("UserToParent")
  department      DepartmentTrack? @relation(fields: [departmentId], references: [id])
  companyAsRoot   Company?         @relation("RootUser")

  @@index([walletNumber])
  @@index([privyId])
}

model Company {
  id           String   @id @default(uuid())
  name         String
  rootUserId   String?  @unique @map("root_user_id")
  status       String   @default("Em subida") // Em subida / No cume
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  rootUser     User?    @relation("RootUser", fields: [rootUserId], references: [id])
  users        User[]
  departments  DepartmentTrack[]

  @@index([rootUserId])
}

model DepartmentTrack {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  departmentName String   @map("department_name")
  status         String   @default("active")
  kpis           Json     @default("{}")
  progress       Float    @default(0.0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users          User[]

  @@index([companyId])
}
